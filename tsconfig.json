{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "#commands/*.js": ["src/commands/*.ts"],
      "#core/*.js": ["src/core/*.ts"],
      "#utils/*.js": ["src/utils/*.ts"],
      "#types/*.js": ["src/types/*.ts"],
      "#test-utils/*.js": ["src/test-utils/*.ts"],
      "#commands/*": ["src/commands/*"],
      "#core/*": ["src/core/*"],
      "#utils/*": ["src/utils/*"],
      "#types/*": ["src/types/*"],
      "#test-utils/*": ["src/test-utils/*"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "src/test-utils/**"]
}
