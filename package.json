{
  "name": "skill-forge",
  "version": "0.1.0",
  "description": "CLI for authoring and managing personal agent skills registries.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skill-forge": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm run build && pnpm test",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts"
  },
  "keywords": [
    "skill-forge",
    "agent-skills",
    "skills",
    "claude-code"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushil-kamble/skill-forge.git"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "octokit": "^5.0.5",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
