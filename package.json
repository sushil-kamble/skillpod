{
  "name": "skillpod",
  "version": "0.3.1",
  "description": "CLI for authoring and managing personal agent skills registries.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "skillpod": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json && tsc-alias -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm run build && pnpm test",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "skillpod",
    "agent-skills",
    "skills",
    "claude-code"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushil-kamble/skillpod.git"
  },
  "author": "Sushil Kamble",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "octokit": "^5.0.5",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
